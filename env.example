# Copy this file to `.env` for local development. Do not commit your real `.env`.
# Vite only exposes variables prefixed with VITE_ to the browser.

# Base URL for API requests (e.g., https://api.example.com)
VITE_API_BASE_URL=

# Optional: logo provider endpoint (e.g., https://logo.clearbit.com)
VITE_LOGO_BASE_URL=
